# Optional: only needed if you switch Task Master models from codex-cli to API providers.
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# PERPLEXITY_API_KEY="pplx-..."
# GOOGLE_API_KEY="..."

# Optional MCP tool loading mode: core, standard, all, or comma-separated tool names.
TASK_MASTER_TOOLS="standard"
# Local infrastructure for docker compose. Copy .env.example to .env and change these values locally.
TZ=Asia/Shanghai

MYSQL_PORT=3306
MYSQL_DATABASE=minimall_order
MYSQL_USER=minimall
MYSQL_PASSWORD=change-me-mysql
MYSQL_ROOT_PASSWORD=change-me-root

REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis

RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=minimall
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq

PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
PROMETHEUS_PORT=9090

GRAFANA_IMAGE=grafana/grafana-oss:11.3.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
GRAFANA_USERS_ALLOW_SIGN_UP=false
GRAFANA_PROMETHEUS_URL=http://prometheus:9090

# Java service container images and host ports. Build jars first with Maven,
# then start the services profile with Docker Compose.
JAVA_RUNTIME_IMAGE=eclipse-temurin:17-jre-alpine
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
MINIMALL_IMAGE_PREFIX=minimall
MINIMALL_IMAGE_TAG=local

API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8101
PRODUCT_SERVICE_PORT=8102
INVENTORY_SERVICE_PORT=8103
ORDER_SERVICE_PORT=8104
PAYMENT_SERVICE_PORT=8105
NOTIFICATION_SERVICE_PORT=8106

# Spring service connection variables for local development.
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/minimall_order?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
SPRING_DATASOURCE_USERNAME=minimall
SPRING_DATASOURCE_PASSWORD=change-me-mysql

SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=change-me-redis

SPRING_RABBITMQ_HOST=127.0.0.1
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=minimall
SPRING_RABBITMQ_PASSWORD=change-me-rabbitmq
SPRING_RABBITMQ_VIRTUAL_HOST=/

MINIMALL_AUTH_JWT_SECRET=change-me-jwt-secret
MINIMALL_AUTH_JWT_EXPIRE_SECONDS=3600

# Order service timeout cancellation scheduler.
MINIMALL_ORDER_TIMEOUT_ENABLED=true
MINIMALL_ORDER_TIMEOUT_FIXED_DELAY=60000
MINIMALL_ORDER_TIMEOUT_BATCH_SIZE=100

# API gateway CORS defaults for browser-based frontend development.
MINIMALL_GATEWAY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
MINIMALL_GATEWAY_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
MINIMALL_GATEWAY_CORS_ALLOWED_HEADERS=*
MINIMALL_GATEWAY_CORS_ALLOW_CREDENTIALS=false
MINIMALL_GATEWAY_CORS_MAX_AGE=1800

# API gateway Redis-backed token-bucket rate limiting.
MINIMALL_GATEWAY_RATE_LIMIT_ENABLED=true
MINIMALL_GATEWAY_RATE_LIMIT_REPLENISH_RATE=10
MINIMALL_GATEWAY_RATE_LIMIT_BURST_CAPACITY=20
MINIMALL_GATEWAY_RATE_LIMIT_REQUESTED_TOKENS=1
MINIMALL_GATEWAY_RATE_LIMIT_KEY_PREFIX=minimall:gateway:rate-limit
MINIMALL_GATEWAY_RATE_LIMIT_FAIL_OPEN=true
